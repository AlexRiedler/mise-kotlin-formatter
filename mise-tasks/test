#!/usr/bin/env bash
#MISE description="Run plugin tests - install and execute tool"
set -euo pipefail

mise plugin link --force kotlin-formatter .
mise cache clear
mise install kotlin-formatter@1.7.2

output=$(mise exec "kotlin-formatter@1.7.2" -- kotlin-format --help 2>&1)
echo "kotlin-format output: $output"

if echo "$output" | grep -q 'Command-line interface'; then
    echo "✓ Tests passed"
else
    echo "✗ Test failed: expected help output"
    exit 1
fi